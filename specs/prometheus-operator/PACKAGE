# -*- mode: shell-script; sh-basic-offset: 2; -*-

# Maintainer: @dnaeon

NAME=prometheus-operator
VERSION=0.89.0
DESCRIPTION="Prometheus Operator"

package() {
  # Fetch the upstream Prometheus Operator manifests and configure the namespace.
  #
  # See [1] for more details.
  #
  # [1]: https://prometheus-operator.dev/docs/getting-started/installation/#install-using-yaml-files
  curl -Ls \
       -o "${SRC_DIR}/bundle.yaml" \
       "https://raw.githubusercontent.com/prometheus-operator/prometheus-operator/refs/tags/v${VERSION}/bundle.yaml"

  ${KUSTOMIZE} edit set namespace "${PACK_NAMESPACE}"

  # Build the kustomization and slice it up
  ${KUSTOMIZE} build | \
    ${KUBECTL_SLICE} --exclude-kind Namespace -f - --output-dir ${PACK_DIR}/
}

package_test() {
  ${KUBECONFORM} \
    -strict \
    -verbose \
    -summary \
    -output pretty \
    -schema-location default \
    -schema-location "https://raw.githubusercontent.com/yannh/kubernetes-json-schema/master/{{.NormalizedKubernetesVersion}}/{{.ResourceKind}}.json" \
    ${PACK_DIR}
}
